# Supabase: valores públicos usados por el navegador y las sesiones autenticadas
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Solo servidor. No usar prefijo VITE_ ni exponer en el navegador.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# Solo servidor
GROQ_API_KEY=gsk_xxx
AI_MODEL=llama-3.3-70b-versatile

# Integración opcional con Telegram (solo servidor)
TELEGRAM_BOT_USERNAME=tu_bot_sin_arroba
TELEGRAM_BOT_TOKEN=123456:ABCDEF
# Debe coincidir con secret_token al registrar el webhook en Telegram.
TELEGRAM_WEBHOOK_SECRET=cambia_este_valor_largo_y_aleatorio
